# ── moteur de calcul ──────────────────────────────────────────────────────────

def simulate_gbm_paths(S0, r, sigma, T, n_steps, n_paths, seed=7):
rng = np.random.default_rng(seed)
dt = T / n_steps
Z = rng.standard_normal((n_paths, n_steps))
drift = (r - 0.5 * sigma * sigma) * dt
vol = sigma * math.sqrt(dt)
logS = np.empty((n_paths, n_steps + 1))
logS[:, 0] = math.log(S0)
logS[:, 1:] = logS[:, 0:1] + np.cumsum(drift + vol * Z, axis=1)
return np.exp(logS)

def phoenix_cashflows(paths, Sref, r, T, obs_per_year,
coupon_rate, coupon_barrier, autocall_barrier,
protection_barrier, notional=100.0):
“”“Version vectorisée : boucle sur les dates d’observation, pas sur les paths.”””
n_paths = paths.shape[0]
n_obs = int(obs_per_year * T)
t_obs = np.arange(1, n_obs + 1) / n_obs * T
disc = np.exp(-r * t_obs)

```
call_lvl = autocall_barrier * Sref
cpn_lvl  = coupon_barrier   * Sref
prot_lvl = protection_barrier * Sref

S_obs = paths[:, 1:]           # (n_paths, n_obs)

pv         = np.zeros(n_paths)
payoff     = np.zeros(n_paths)
called_at  = np.full(n_paths, -1, dtype=int)
cum_cpn    = np.zeros(n_paths, dtype=int)
active     = np.ones(n_paths,  dtype=bool)

for k in range(n_obs):
    t = t_obs[k]; d = disc[k]

    cpn_mask = active & (S_obs[:, k] >= cpn_lvl)
    pv[cpn_mask]  += notional * coupon_rate * d
    cum_cpn[cpn_mask] += 1

    call_mask = active & (S_obs[:, k] >= call_lvl)
    pv[call_mask]       += notional * d
    called_at[call_mask] = k + 1
    payoff[call_mask]    = notional * (1 + coupon_rate * cum_cpn[call_mask])
    active[call_mask]    = False

ST = paths[active, -1]
redemption = np.where(ST >= prot_lvl, notional, notional * ST / Sref)
pv[active]     += redemption * math.exp(-r * T)
payoff[active]  = redemption + notional * coupon_rate * cum_cpn[active]

return pv, payoff, called_at, cum_cpn
```

def run_pricing(params):
S0    = params[“spot”];  Sref  = params[“Sref”]
r     = params[“r”];     sigma = params[“sigma”]
T     = params[“T”];     obs   = params[“obs_per_year”]
n     = params[“n_paths”]; seed = params.get(“seed”, 7)
n_obs = int(obs * T)

```
paths = simulate_gbm_paths(S0, r, sigma, T, n_obs, n, seed)
pv, payoff, called_at, n_coupons = phoenix_cashflows(
    paths, Sref, r, T, obs,
    params["coupon_rate"], params["coupon_barrier"],
    params["autocall_barrier"], params["protection_barrier"],
    params.get("notional", 100.0)
)

price       = float(pv.mean())
stderr      = float(pv.std(ddof=1) / math.sqrt(n))
prob_called = float((called_at != -1).mean())
avg_call    = float(((called_at[called_at != -1] / n_obs) * T).mean()) \
              if prob_called > 0 else None
cr          = (payoff / params.get("notional", 100.0)) - 1.0

return dict(price=price, stderr=stderr, prob_called=prob_called,
            avg_call_time=avg_call, pv=pv, payoff=payoff,
            client_return=cr, called_at=called_at,
            paths_sample=paths[:300, :], n_obs=n_obs)
```

def run_scenario_grid(base, spot_shocks=(-0.20, -0.10, 0.0, 0.10, 0.20),
vol_shocks=(-0.05, 0.0, 0.05)):
rows = []
for ds in spot_shocks:
for dv in vol_shocks:
p = base.copy()
p[“spot”]  = base[“spot”]  * (1 + ds)
p[“sigma”] = max(1e-4, base[“sigma”] + dv)
res = run_pricing(p)
cr  = res[“client_return”]
rows.append(dict(
spot_shock=ds, vol_shock=dv,
price=res[“price”],
prob_autocall=res[“prob_called”],
prob_loss=float((cr < 0).mean()),
median_return=float(np.median(cr)),
p5_return=float(np.quantile(cr, 0.05))
))
return pd.DataFrame(rows)

