# ── style ─────────────────────────────────────────────────────────────────

def _style(self):
    s = ttk.Style(self)
    s.theme_use("clam")
    s.configure(".",           background=DARK, foreground=FG, font=("Segoe UI", 9))
    s.configure("TFrame",      background=DARK)
    s.configure("TLabel",      background=DARK, foreground=FG)
    s.configure("TEntry",      fieldbackground=PANEL, foreground=FG,
                insertcolor=FG, borderwidth=0)
    s.configure("TButton",     background=PANEL, foreground=FG, relief="flat",
                padding=5, focusthickness=0)
    s.map("TButton",           background=[("active", ACCENT)],
                               foreground=[("active", DARK)])
    s.configure("TLabelframe", background=DARK, foreground=ACCENT,
                bordercolor=PANEL)
    s.configure("TLabelframe.Label", background=DARK, foreground=ACCENT,
                font=("Segoe UI", 9, "bold"))
    s.configure("TNotebook",   background=DARK, borderwidth=0)
    s.configure("TNotebook.Tab", background=PANEL, foreground=FG, padding=(10, 4))
    s.map("TNotebook.Tab",     background=[("selected", ACCENT)],
                               foreground=[("selected", DARK)])
    s.configure("TSeparator",  background=PANEL)

# ── layout ────────────────────────────────────────────────────────────────

def _build(self):
    # colonne gauche
    left = ttk.Frame(self, padding=(12, 12, 6, 12))
    left.grid(row=0, column=0, sticky="ns")

    ttk.Label(left, text="Paramètres",
              font=("Segoe UI", 10, "bold"), foreground=ACCENT).grid(
        row=0, column=0, columnspan=2, sticky="w", pady=(0, 8))

    self.entries = {}
    for i, (lbl, key, val) in enumerate(PARAMS_DEF, start=1):
        ttk.Label(left, text=lbl, anchor="w").grid(
            row=i, column=0, sticky="w", pady=2)
        e = ttk.Entry(left, width=10, justify="right")
        e.insert(0, val)
        e.grid(row=i, column=1, sticky="e", padx=(8, 0), pady=2)
        self.entries[key] = e

    ttk.Separator(left, orient="horizontal").grid(
        row=len(PARAMS_DEF)+1, columnspan=2, sticky="ew", pady=10)

    btn_run = ttk.Button(left, text="▶  Lancer", command=self._run)
    btn_run.grid(row=len(PARAMS_DEF)+2, columnspan=2, sticky="ew", pady=2)

    btn_grid = ttk.Button(left, text="⊞  Grille de scénarios", command=self._run_grid)
    btn_grid.grid(row=len(PARAMS_DEF)+3, columnspan=2, sticky="ew", pady=2)

    self.lbl_status = ttk.Label(left, text="", foreground="gray",
                                font=("Segoe UI", 8))
    self.lbl_status.grid(row=len(PARAMS_DEF)+4, columnspan=2, pady=(6, 0))

    # colonne droite
    right = ttk.Frame(self, padding=(6, 12, 12, 12))
    right.grid(row=0, column=1, sticky="nsew")
    self.columnconfigure(1, weight=1)
    self.rowconfigure(0, weight=1)
    right.rowconfigure(1, weight=1)
    right.columnconfigure(0, weight=1)

    # bloc métriques
    frm_metrics = ttk.LabelFrame(right, text="Résultats", padding=(10, 6))
    frm_metrics.grid(row=0, column=0, sticky="ew", pady=(0, 10))

    self.metric_vars = {}
    for i, (lbl, key, fmt) in enumerate(METRICS_DEF):
        ttk.Label(frm_metrics, text=lbl, width=26, anchor="w").grid(
            row=i, column=0, sticky="w", pady=1)
        var = tk.StringVar(value="—")
        ttk.Label(frm_metrics, textvariable=var, width=14, anchor="e",
                  font=FONT_MONO, foreground=ACCENT).grid(
            row=i, column=1, sticky="e", padx=(12, 0), pady=1)
        self.metric_vars[key] = (var, fmt)

    # onglets graphiques
    nb = ttk.Notebook(right)
    nb.grid(row=1, column=0, sticky="nsew")

    self.tab_distrib = ttk.Frame(nb)
    self.tab_paths   = ttk.Frame(nb)
    nb.add(self.tab_distrib, text="  Distribution  ")
    nb.add(self.tab_paths,   text="  Trajectoires  ")

# ── actions ───────────────────────────────────────────────────────────────

def _read_params(self):
    p = {}
    for key, e in self.entries.items():
        raw = e.get().strip().replace(",", ".")
        p[key] = int(float(raw)) if key in ("n_paths", "obs_per_year") else float(raw)
    p["seed"] = 7
    return p

def _set_status(self, msg, color="gray"):
    self.lbl_status.config(text=msg, foreground=color)
    self.update_idletasks()

def _run(self):
    try:
        params = self._read_params()
    except ValueError:
        messagebox.showerror("Erreur", "Paramètre invalide.")
        return
    self._set_status("Calcul en cours…")
    try:
        res = run_pricing(params)
    except Exception as ex:
        messagebox.showerror("Erreur calcul", str(ex))
        self._set_status("Erreur", RED)
        return
    self._update_metrics(res)
    self._draw_distrib(res)
    self._draw_paths(res, params)
    self._set_status("✓ Terminé", GREEN)

def _run_grid(self):
    try:
        params = self._read_params()
    except ValueError:
        messagebox.showerror("Erreur", "Paramètre invalide.")
        return
    self._set_status("Grille en cours… (quelques secondes)")
    try:
        df = run_scenario_grid(params)
    except Exception as ex:
        messagebox.showerror("Erreur", str(ex))
        self._set_status("Erreur", RED)
        return
    self._show_grid(df)
    self._set_status("✓ Grille calculée", GREEN)

# ── métriques ─────────────────────────────────────────────────────────────

def _update_metrics(self, res):
    cr = res["client_return"]
    vals = {
        "price":        res["price"],
        "stderr":       res["stderr"],
        "prob_called":  res["prob_called"],
        "avg_call_time":res["avg_call_time"] or 0.0,
        "median_ret":   float(np.median(cr)),
        "p5_ret":       float(np.quantile(cr, 0.05)),
        "prob_loss":    float((cr < 0).mean()),
    }
    for key, (var, fmt) in self.metric_vars.items():
        var.set(fmt.format(vals[key]))

# ── graphiques ────────────────────────────────────────────────────────────

def _embed(self, fig, parent):
    for w in parent.winfo_children():
        w.destroy()
    canvas = FigureCanvasTkAgg(fig, master=parent)
    canvas.draw()
    canvas.get_tk_widget().pack(fill="both", expand=True)
    plt.close(fig)

def _draw_distrib(self, res):
    fig, ax = plt.subplots(figsize=(6, 3.6), dpi=96,
                           facecolor=DARK)
    ax.set_facecolor(PANEL)
    cr = res["client_return"] * 100
    ax.hist(cr, bins=60, color=ACCENT, edgecolor="none", alpha=0.85)
    ax.axvline(0, color=RED, linewidth=1.3, linestyle="--", label="seuil perte (0%)")
    med = float(np.median(cr))
    ax.axvline(med, color=GREEN, linewidth=1.1, linestyle=":", label=f"médiane ({med:.1f}%)")
    ax.set_xlabel("Rendement client (%)", color=FG)
    ax.set_ylabel("Fréquence", color=FG)
    ax.set_title("Distribution des rendements simulés", color=FG)
    ax.tick_params(colors=FG)
    for sp in ax.spines.values():
        sp.set_edgecolor(PANEL)
    ax.legend(fontsize=8, facecolor=PANEL, labelcolor=FG)
    fig.tight_layout(pad=1.2)
    self._embed(fig, self.tab_distrib)

def _draw_paths(self, res, params):
    fig, ax = plt.subplots(figsize=(6, 3.6), dpi=96,
                           facecolor=DARK)
    ax.set_facecolor(PANEL)
    paths = res["paths_sample"]
    T = params["T"]
    t_grid = np.linspace(0, T, paths.shape[1])
    Sref = params["Sref"]

    for i in range(min(50, paths.shape[0])):
        ax.plot(t_grid, paths[i], alpha=0.22, linewidth=0.6, color=ACCENT)

    ax.axhline(Sref * params["autocall_barrier"],   color=GREEN,  linewidth=1.1,
               linestyle="--", label=f"rappel ({params['autocall_barrier']:.0%})")
    ax.axhline(Sref * params["coupon_barrier"],     color=YELLOW, linewidth=1.0,
               linestyle=":",  label=f"coupon ({params['coupon_barrier']:.0%})")
    ax.axhline(Sref * params["protection_barrier"], color=RED,    linewidth=1.0,
               linestyle="-.", label=f"protection ({params['protection_barrier']:.0%})")
    ax.axhline(Sref, color="white", linewidth=0.7, alpha=0.4, linestyle="-")

    ax.set_xlabel("Temps (ans)", color=FG)
    ax.set_ylabel("Niveau sous-jacent", color=FG)
    ax.set_title("Trajectoires simulées — échantillon", color=FG)
    ax.tick_params(colors=FG)
    for sp in ax.spines.values():
        sp.set_edgecolor(PANEL)
    ax.legend(fontsize=7, facecolor=PANEL, labelcolor=FG)
    fig.tight_layout(pad=1.2)
    self._embed(fig, self.tab_paths)

# ── fenêtre grille ────────────────────────────────────────────────────────

def _show_grid(self, df):
    win = tk.Toplevel(self)
    win.title("Grille de scénarios — spot × volatilité")
    win.configure(bg=DARK)
    win.minsize(900, 380)

    spot_sh = sorted(df["spot_shock"].unique())
    vol_sh  = sorted(df["vol_shock"].unique())

    cols = [
        ("price",         "Prix (PV)",         "{:.2f}", "RdYlGn"),
        ("prob_autocall", "Prob. rappel",       "{:.0%}", "RdYlGn"),
        ("median_return", "Rendement médian",   "{:.1%}", "RdYlGn"),
    ]

    fig, axes = plt.subplots(1, 3, figsize=(12, 3.8), dpi=96,
                             facecolor=DARK)
    fig.suptitle("Grille de scénarios  (lignes = choc vol σ, colonnes = choc spot)",
                 color=FG, fontsize=9)

    for ax, (col, title, fmt, cmap) in zip(axes, cols):
        mat = df.pivot(index="vol_shock", columns="spot_shock", values=col)
        mat = mat.reindex(index=vol_sh, columns=spot_sh).values

        im = ax.imshow(mat, cmap=cmap, aspect="auto")
        ax.set_xticks(range(len(spot_sh)))
        ax.set_xticklabels([f"{s:+.0%}" for s in spot_sh], fontsize=8, color=FG)
        ax.set_yticks(range(len(vol_sh)))
        ax.set_yticklabels([f"{v:+.2f}" for v in vol_sh], fontsize=8, color=FG)
        ax.set_xlabel("Choc spot", fontsize=8, color=FG)
        ax.set_ylabel("Choc vol (Δσ)", fontsize=8, color=FG)
        ax.set_title(title, fontsize=9, color=FG, pad=6)
        ax.tick_params(colors=FG, length=0)
        for sp in ax.spines.values():
            sp.set_visible(False)

        for r in range(mat.shape[0]):
            for c in range(mat.shape[1]):
                ax.text(c, r, fmt.format(mat[r, c]),
                        ha="center", va="center", fontsize=8,
                        color="black", fontweight="bold")
        cb = fig.colorbar(im, ax=ax, shrink=0.75, pad=0.02)
        cb.ax.tick_params(colors=FG, labelsize=7)

    fig.tight_layout(rect=[0, 0, 1, 0.93])
    canvas = FigureCanvasTkAgg(fig, master=win)
    canvas.draw()
    canvas.get_tk_widget().pack(fill="both", expand=True, padx=8, pady=8)
    plt.close(fig)
